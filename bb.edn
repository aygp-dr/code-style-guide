{:paths ["src"]
 :deps {org.babashka/cli {:mvn/version "0.8.61"}
        org.babashka/fs {:mvn/version "0.5.22"}}
 :tasks
 {check {:doc "Check files for style violations"
         :task (exec 'code-style-guide.core/-main)
         :exec-args {:format "text"}}
  fix {:doc "Auto-fix style violations where possible"
       :task (exec 'code-style-guide.core/-main)
       :exec-args {:fix true :format "text"}}}}
